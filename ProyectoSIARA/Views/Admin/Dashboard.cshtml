@{
    ViewData["Title"] = "Cursos y Docentes";
}

<div class="encabezado-pantalla">
    <h2>CURSOS Y DOCENTES</h2>
    <div class="botones-accion">
        <button class="btn" onclick="abrirModal('modalNuevoDocente')">+ AGREGAR NUEVO DOCENTE</button>
        <button class="btn btn-secundario">MAPEADO DE CURSOS</button>
        <button class="btn btn-secundario" onclick="abrirModal('modalAgregarAsignatura')">+ AGREGAR ASIGNATURA</button>
        <button class="btn btn-secundario" onclick="abrirModal('modalFechaCorte')">ASIGNAR FECHA DE CORTE</button>
    </div>
</div>

<table class="tabla-siara">
    <thead>
        <tr>
            <th>NO.</th>
            <th>DOCENTE</th>
            <th>ASIGNATURAS</th>
            <th>INDICE DE APROBACIÓN</th>
            <th>INDICE DE REPROBACIÓN</th>
            <th>TASA DE DESERCIÓN</th>
            <th>ACCIONES</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td>1</td>
            <td>DOCENTE 1</td>
            <td>2</td>
            <td style="color: var(--verde-aprobado);">67%</td>
            <td style="color: var(--naranja-reprobado);">30%</td>
            <td style="color: var(--rojo-alerta);">3%</td>
            <td><button class="btn-pequeno" style="background-color: #333;" onclick="abrirModal('modalEditarDocente')">✏️ Editar</button></td>
        </tr>
        <tr>
            <td>2</td>
            <td>DOCENTE 2</td>
            <td>3</td>
            <td style="color: var(--verde-aprobado);">67%</td>
            <td style="color: var(--naranja-reprobado);">30%</td>
            <td style="color: var(--rojo-alerta);">3%</td>
            <td><button class="btn-pequeno" style="background-color: #333;" onclick="abrirModal('modalEditarDocente')">✏️ Editar</button></td>
        </tr>
    </tbody>
</table>

<div id="modalNuevoDocente" class="fondo-modal">
    <div class="ventana-modal">
        <button class="btn-cerrar-modal" onclick="cerrarModal('modalNuevoDocente')">X</button>
        <div class="header-modal">&#128100; + NUEVO DOCENTE</div>
        <div class="cuerpo-modal">
            <div style="text-align: center; font-weight: bold; font-size: 12px; margin-bottom: 15px;">DATOS DEL DOCENTE</div>
            <input type="text" placeholder="NOMBRE COMPLETO" style="width: 100%; border: 2px solid #000; padding: 8px; margin-bottom: 10px; font-weight: bold; text-align: center; border-radius: 5px;">
            <input type="text" placeholder="RFC" style="width: 100%; border: 2px solid #000; padding: 8px; margin-bottom: 10px; font-weight: bold; text-align: center; border-radius: 5px;">
            <input type="text" placeholder="ID DE EMPLEADO" style="width: 100%; border: 2px solid #000; padding: 8px; margin-bottom: 10px; font-weight: bold; text-align: center; border-radius: 5px;">
            <input type="email" placeholder="CORREO ELECTRONICO" style="width: 100%; border: 2px solid #000; padding: 8px; margin-bottom: 20px; font-weight: bold; text-align: center; border-radius: 5px;">
            <button class="btn" style="width: 100%;" onclick="mostrarAlertaExito('DOCENTE AGREGADO<br>CORRECTAMENTE', 'modalNuevoDocente')">GUARDAR Y ENVIAR</button>
        </div>
    </div>
</div>

<div id="modalEditarDocente" class="fondo-modal">
    <div class="ventana-modal">
        <button class="btn-cerrar-modal" onclick="cerrarModal('modalEditarDocente')">X</button>
        <div class="header-modal">&#128100; EDITAR DOCENTE</div>
        <div class="cuerpo-modal">
            <div class="switch-container">
                <span style="font-weight: bold; font-size: 12px;">DATOS DEL DOCENTE</span>
                <label class="switch"><input type="checkbox" checked><span class="slider"></span></label>
                <span style="font-size: 20px; cursor: pointer;" onclick="mostrarAlertaConfirmacion('¿ELIMINAR USUARIO?', 'modalEditarDocente')">&#128465;</span>
            </div>
            <input type="text" value="NOMBRE COMPLETO" style="width: 100%; border: 2px solid #000; padding: 8px; margin-bottom: 10px; font-weight: bold; text-align: center; border-radius: 5px; color: #888;">
            <input type="text" value="RFC" style="width: 100%; border: 2px solid #000; padding: 8px; margin-bottom: 10px; font-weight: bold; text-align: center; border-radius: 5px; color: #888;">
            <input type="text" value="ID DE EMPLEADO" style="width: 100%; border: 2px solid #000; padding: 8px; margin-bottom: 10px; font-weight: bold; text-align: center; border-radius: 5px; color: #888;">
            <input type="email" value="CORREO ELECTRONICO" style="width: 100%; border: 2px solid #000; padding: 8px; margin-bottom: 20px; font-weight: bold; text-align: center; border-radius: 5px; color: #888;">
            <div class="botones-modal">
                <button class="btn btn-secundario" onclick="cerrarModal('modalEditarDocente')">CANCELAR</button>
                <button class="btn" onclick="mostrarAlertaExito('CAMBIOS GUARDADOS', 'modalEditarDocente')">GUARDAR</button>
            </div>
        </div>
    </div>
</div>

<div id="modalAgregarAsignatura" class="fondo-modal">
    <div class="ventana-modal">
        <button class="btn-cerrar-modal" onclick="cerrarModal('modalAgregarAsignatura')">X</button>
        <div class="header-modal">AGREGAR ASIGNATURA A DOCENTE</div>
        <div class="cuerpo-modal">
            <div class="fila-formulario"><label>DOCENTE</label><input type="text" value="DOCENTE 1" readonly></div>
            <div class="fila-formulario">
                <label>ASIGNATURA</label>
                <select>
                    <option>DESARROLLO SUSTENTABLE</option>
                </select>
            </div>
            <div class="fila-formulario"><label>CLAVE</label><input type="text" value="H1B63" readonly></div>
            <div class="fila-formulario"><label>HORAS</label><input type="text" value="48" readonly></div>
            <div class="fila-formulario"><label>TEMAS</label><input type="text"></div>
            <div class="botones-modal">
                <button class="btn btn-secundario" onclick="cerrarModal('modalAgregarAsignatura')">CANCELAR</button>
                <button class="btn" onclick="mostrarAlertaExito('DATOS AGREGADOS<br>CORRECTAMENTE', 'modalAgregarAsignatura')">GUARDAR</button>
            </div>
        </div>
    </div>
</div>

<div id="modalFechaCorte" class="fondo-modal">
    <div class="ventana-modal">
        <button class="btn-cerrar-modal" onclick="cerrarModal('modalFechaCorte')">X</button>
        <div class="header-modal" style="text-align: left;">&#128197; FECHA DE CORTE</div>
        <div class="cuerpo-modal">
            <div class="fila-formulario">
                <label>SEGUIMIENTO</label>
                <select><option>PRIMER SEGUIMIENTO</option></select>
            </div>
            <div class="fila-formulario">
                <label>FECHA DE CORTE</label>
                <input type="text" value="03/02/2026">
            </div>
            <div class="botones-modal">
                <button class="btn btn-secundario" onclick="cerrarModal('modalFechaCorte')">CANCELAR</button>
                <button class="btn" onclick="mostrarAlertaExito('FECHA GUARDADA<br>CON ÉXITO', 'modalFechaCorte')">GUARDAR</button>
            </div>
        </div>
    </div>
</div>

<div id="alertaSistema" class="fondo-modal" style="z-index: 1100;">
    <div class="ventana-alerta">
        <div id="iconoAlerta" class="icono-alerta" style="color: #28a745;">&#10004;</div>
        <div id="textoAlerta" class="texto-alerta">GUARDADO<br>EXITOSO</div>
        <button class="btn" style="width: 150px; background-color: #6a8bad; border-color: #517192;" onclick="cerrarAlerta()">ACEPTAR</button>
    </div>
</div>

<script>
    // Función para abrir un modal específico
    function abrirModal(idModal) {
        document.getElementById(idModal).style.display = 'flex';
    }

    // Función para cerrar un modal específico
    function cerrarModal(idModal) {
        document.getElementById(idModal).style.display = 'none';
    }

    // Función para mostrar alerta de Éxito (Palomita verde)
    function mostrarAlertaExito(mensaje, modalACerrar = null) {
        if(modalACerrar) cerrarModal(modalACerrar); // Cierra el modal de fondo si existe
        document.getElementById('iconoAlerta').innerHTML = '&#10004;';
        document.getElementById('iconoAlerta').style.color = '#28a745';
        document.getElementById('textoAlerta').innerHTML = mensaje;
        document.getElementById('alertaSistema').style.display = 'flex';
    }

    // Función para mostrar alerta de Confirmación/Advertencia (Triángulo amarillo)
    function mostrarAlertaConfirmacion(mensaje, modalACerrar = null) {
        if(modalACerrar) cerrarModal(modalACerrar);
        document.getElementById('iconoAlerta').innerHTML = '&#9888;'; // Triángulo de advertencia
        document.getElementById('iconoAlerta').style.color = '#ffc107';
        document.getElementById('textoAlerta').innerHTML = mensaje;
        document.getElementById('alertaSistema').style.display = 'flex';
    }

    // Función para cerrar la alerta
    function cerrarAlerta() {
        document.getElementById('alertaSistema').style.display = 'none';
    }
</script>